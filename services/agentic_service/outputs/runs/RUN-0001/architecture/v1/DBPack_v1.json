{
  "project_name": "AutoForge Shop",
  "version": "v1",
  "database_type": "relational",
  "entities": [
    {
      "id": "DE-001",
      "name": "User",
      "description": "Represents a customer or admin user.",
      "attributes": [
        {
          "name": "id",
          "type": "uuid",
          "required": true,
          "description": "Unique user ID."
        },
        {
          "name": "name",
          "type": "string",
          "required": true,
          "description": "Full name of the user."
        },
        {
          "name": "email",
          "type": "string",
          "required": true,
          "description": "Unique email address."
        },
        {
          "name": "password_hash",
          "type": "string",
          "required": true,
          "description": "Hashed password."
        },
        {
          "name": "role",
          "type": "string",
          "required": true,
          "description": "User role such as CUSTOMER or ADMIN."
        },
        {
          "name": "created_at",
          "type": "datetime",
          "required": true,
          "description": "Account creation timestamp."
        }
      ]
    },
    {
      "id": "DE-002",
      "name": "Category",
      "description": "Represents a product category.",
      "attributes": [
        {
          "name": "id",
          "type": "uuid",
          "required": true,
          "description": "Unique category ID."
        },
        {
          "name": "name",
          "type": "string",
          "required": true,
          "description": "Category name."
        },
        {
          "name": "description",
          "type": "string",
          "required": false,
          "description": "Category description."
        }
      ]
    },
    {
      "id": "DE-003",
      "name": "Product",
      "description": "Represents a product available for sale.",
      "attributes": [
        {
          "name": "id",
          "type": "uuid",
          "required": true,
          "description": "Unique product ID."
        },
        {
          "name": "category_id",
          "type": "uuid",
          "required": true,
          "description": "Related category ID."
        },
        {
          "name": "name",
          "type": "string",
          "required": true,
          "description": "Product name."
        },
        {
          "name": "description",
          "type": "text",
          "required": true,
          "description": "Product description."
        },
        {
          "name": "price",
          "type": "decimal",
          "required": true,
          "description": "Product selling price."
        },
        {
          "name": "stock_quantity",
          "type": "integer",
          "required": true,
          "description": "Available stock quantity."
        },
        {
          "name": "image_url",
          "type": "string",
          "required": false,
          "description": "Product image URL."
        },
        {
          "name": "is_active",
          "type": "boolean",
          "required": true,
          "description": "Whether product is active."
        }
      ]
    },
    {
      "id": "DE-004",
      "name": "Cart",
      "description": "Represents a customer's shopping cart.",
      "attributes": [
        {
          "name": "id",
          "type": "uuid",
          "required": true,
          "description": "Unique cart ID."
        },
        {
          "name": "user_id",
          "type": "uuid",
          "required": true,
          "description": "Owner user ID."
        },
        {
          "name": "created_at",
          "type": "datetime",
          "required": true,
          "description": "Cart creation timestamp."
        },
        {
          "name": "updated_at",
          "type": "datetime",
          "required": true,
          "description": "Cart update timestamp."
        }
      ]
    },
    {
      "id": "DE-005",
      "name": "CartItem",
      "description": "Represents one product item inside a cart.",
      "attributes": [
        {
          "name": "id",
          "type": "uuid",
          "required": true,
          "description": "Unique cart item ID."
        },
        {
          "name": "cart_id",
          "type": "uuid",
          "required": true,
          "description": "Related cart ID."
        },
        {
          "name": "product_id",
          "type": "uuid",
          "required": true,
          "description": "Related product ID."
        },
        {
          "name": "quantity",
          "type": "integer",
          "required": true,
          "description": "Product quantity in cart."
        },
        {
          "name": "unit_price",
          "type": "decimal",
          "required": true,
          "description": "Price at the time of adding to cart."
        }
      ]
    },
    {
      "id": "DE-006",
      "name": "Order",
      "description": "Represents a placed customer order.",
      "attributes": [
        {
          "name": "id",
          "type": "uuid",
          "required": true,
          "description": "Unique order ID."
        },
        {
          "name": "user_id",
          "type": "uuid",
          "required": true,
          "description": "Customer who placed the order."
        },
        {
          "name": "status",
          "type": "string",
          "required": true,
          "description": "Order status."
        },
        {
          "name": "total_amount",
          "type": "decimal",
          "required": true,
          "description": "Final order total."
        },
        {
          "name": "created_at",
          "type": "datetime",
          "required": true,
          "description": "Order creation timestamp."
        }
      ]
    },
    {
      "id": "DE-007",
      "name": "OrderItem",
      "description": "Represents one product line item inside an order.",
      "attributes": [
        {
          "name": "id",
          "type": "uuid",
          "required": true,
          "description": "Unique order item ID."
        },
        {
          "name": "order_id",
          "type": "uuid",
          "required": true,
          "description": "Related order ID."
        },
        {
          "name": "product_id",
          "type": "uuid",
          "required": true,
          "description": "Related product ID."
        },
        {
          "name": "quantity",
          "type": "integer",
          "required": true,
          "description": "Purchased quantity."
        },
        {
          "name": "unit_price",
          "type": "decimal",
          "required": true,
          "description": "Product price at purchase time."
        }
      ]
    },
    {
      "id": "DE-008",
      "name": "Payment",
      "description": "Represents payment information for an order.",
      "attributes": [
        {
          "name": "id",
          "type": "uuid",
          "required": true,
          "description": "Unique payment ID."
        },
        {
          "name": "order_id",
          "type": "uuid",
          "required": true,
          "description": "Related order ID."
        },
        {
          "name": "method",
          "type": "string",
          "required": true,
          "description": "Payment method."
        },
        {
          "name": "status",
          "type": "string",
          "required": true,
          "description": "Payment status."
        },
        {
          "name": "transaction_reference",
          "type": "string",
          "required": false,
          "description": "Mock or real payment reference."
        }
      ]
    },
    {
      "id": "DE-009",
      "name": "Address",
      "description": "Represents customer shipping or billing address.",
      "attributes": [
        {
          "name": "id",
          "type": "uuid",
          "required": true,
          "description": "Unique address ID."
        },
        {
          "name": "user_id",
          "type": "uuid",
          "required": true,
          "description": "Owner user ID."
        },
        {
          "name": "line1",
          "type": "string",
          "required": true,
          "description": "Address line 1."
        },
        {
          "name": "city",
          "type": "string",
          "required": true,
          "description": "City."
        },
        {
          "name": "postal_code",
          "type": "string",
          "required": true,
          "description": "Postal code."
        },
        {
          "name": "country",
          "type": "string",
          "required": true,
          "description": "Country."
        }
      ]
    }
  ],
  "relationships": [
    {
      "source": "User",
      "target": "Cart",
      "relationship": "1 to 1",
      "description": "One user owns one active cart."
    },
    {
      "source": "Cart",
      "target": "CartItem",
      "relationship": "1 to many",
      "description": "One cart contains many cart items."
    },
    {
      "source": "Product",
      "target": "CartItem",
      "relationship": "1 to many",
      "description": "A product can appear in many cart items."
    },
    {
      "source": "User",
      "target": "Order",
      "relationship": "1 to many",
      "description": "One user can place many orders."
    },
    {
      "source": "Order",
      "target": "OrderItem",
      "relationship": "1 to many",
      "description": "One order contains many order items."
    },
    {
      "source": "Product",
      "target": "OrderItem",
      "relationship": "1 to many",
      "description": "A product can appear in many order items."
    },
    {
      "source": "Order",
      "target": "Payment",
      "relationship": "1 to 1",
      "description": "One order has one payment record."
    },
    {
      "source": "Category",
      "target": "Product",
      "relationship": "1 to many",
      "description": "One category contains many products."
    },
    {
      "source": "User",
      "target": "Address",
      "relationship": "1 to many",
      "description": "One user can have many addresses."
    }
  ],
  "indexes": [
    "User.email unique index",
    "Product.category_id index",
    "Product.name search index",
    "Cart.user_id index",
    "Order.user_id index",
    "Order.status index"
  ],
  "constraints": [
    "Product.stock_quantity must be greater than or equal to 0.",
    "Product.price must be greater than or equal to 0.",
    "CartItem.quantity must be greater than 0.",
    "Order.total_amount must be greater than or equal to 0.",
    "User.email must be unique."
  ]
}